C_BG       = "#05070A" # Derin Uzay Siyahı
C_PANEL    = "#0D1117" # Panel Rengi
C_ACCENT   = "#00F2FF" # Siber Mavi
C_GREEN    = "#00FF95" # Güvenli Yeşil
C_DANGER   = "#FF0055" # Kritik Kırmızı
